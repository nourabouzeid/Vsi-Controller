add component -type Python -name simulator
add port -componentName simulator -name simulator -gateway python2DtEthernet

add component -type Python -name controller
add port -componentName controller -name controller -gateway python2DtEthernet

add component -type Python -name visualizer
add port -componentName visualizer -name visualizer -gateway python2DtEthernet


config port -componentName simulator -portName simulator -macAddress 12:34:56:78:9A:BC -ipAddress 192.168.1.1
config port -componentName controller -portName controller -macAddress 12:34:56:78:9A:BD -ipAddress 192.168.1.2
config port -componentName visualizer -portName visualizer -macAddress 12:34:56:78:9A:BE -ipAddress 192.168.1.3

define componentSignals -componentName simulator -signals [pose:double[3]:output, path:double[2]:output, control:double[2]:input]
define componentSignals -componentName controller -signals [pose:double[3]:input, path:double[2]:input, control:double[2]:output]
define componentSignals -componentName visualizer -signals [pose:double[3]:input, path:double[2]:input]


add portSocket -componentName simulator -portName simulator -ipPortNum 8070 -socketType server -protocol tcpIp

add portSocket -componentName controller -portName controller -ipPortNum 8070 -socketType client -protocol tcpIp

add portSocket -componentName visualizer -portName visualizer -ipPortNum 8070 -socketType client -protocol tcpIp


connect signals -sourceSignal simulator.pose -destSignal controller.pose -sourcePortName simulator -destPortName controller
connect signals -sourceSignal simulator.pose -destSignal visualizer.pose -sourcePortName simulator -destPortName visualizer

connect signals -sourceSignal simulator.path -destSignal controller.path -sourcePortName simulator -destPortName controller
connect signals -sourceSignal simulator.path -destSignal visualizer.path -sourcePortName simulator -destPortName visualizer

connect signals -sourceSignal controller.control -destSignal simulator.control -sourcePortName controller -destPortName simulator


set digitalTwinName carlaAiAgentDigitalTwin
set workspaceDir .
set simulationStep 0.1 s
set totalSimTime 60 s
generate


